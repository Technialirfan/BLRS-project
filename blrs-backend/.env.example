# .env.example - copy to .env and fill values

# -- SERVER --
PORT=5000
NODE_ENV=development

# -- MONGODB --
MONGODB_URI=mongodb://localhost:27017/blrs_db

# -- JWT --
JWT_SECRET=blrs_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=24h
JWT_COOKIE_EXPIRES=24

# -- BLOCKCHAIN --
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
ROLE_MANAGER_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
LAND_REGISTRY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
DISPUTE_RESOLUTION_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
LAND_TOKEN_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
PATWARI_PRIVATE_KEY=your_patwari_private_key_here
TEHSILDAR_PRIVATE_KEY=your_tehsildar_private_key_here
DC_PRIVATE_KEY=your_dc_private_key_here

# -- IPFS / PINATA --
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_token_here
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# -- CORS --
FRONTEND_URL=http://localhost:5173

# -- RATE LIMITING --
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100