# .env.example - copy this to .env and fill values

# -- For Polygon Amoy Deployment --
# Your MetaMask wallet private key (NEVER share this)
# Export from MetaMask: Account Details -> Export Private Key
PRIVATE_KEY=your_metamask_private_key_here

# Polygon Amoy RPC URL (free - no key needed)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Polygonscan API key (for contract verification)
# Get free key from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# CoinMarketCap API key (for gas cost in USD - optional)
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# -- For Backend Integration --
# These are filled automatically after deployment
LAND_REGISTRY_ADDRESS=
ROLE_MANAGER_ADDRESS=
DISPUTE_RESOLUTION_ADDRESS=
LAND_TOKEN_ADDRESS=